{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universal-ai-tools.local/schemas/tool-contract.schema.json",
  "title": "Universal Tool Contract Manifest",
  "type": "object",
  "required": [
    "version",
    "tools"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "description",
          "stability",
          "inputSchema",
          "execution"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_.-]+$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "stability": {
            "type": "string",
            "enum": [
              "experimental",
              "stable",
              "deprecated"
            ]
          },
          "owner": {
            "type": "string"
          },
          "safetyLevel": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "permissions": {
            "type": "object"
          },
          "inputSchema": {
            "type": "object"
          },
          "execution": {
            "type": "object",
            "required": [
              "command"
            ],
            "properties": {
              "command": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "script": {
                "type": "string"
              },
              "cwd": {
                "type": "string"
              },
              "timeoutMs": {
                "type": "integer",
                "minimum": 1000
              },
              "fixedArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "kind"
                  ],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": [
                        "flag",
                        "option",
                        "positional"
                      ]
                    },
                    "input": {
                      "type": "string"
                    },
                    "flag": {
                      "type": "string"
                    },
                    "option": {
                      "type": "string"
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "default": {},
                    "type": {
                      "type": "string",
                      "enum": [
                        "string",
                        "number",
                        "boolean"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
